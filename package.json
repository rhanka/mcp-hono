{
  "name": "@sentropic/mcp-hono",
  "version": "0.1.3",
  "license": "MIT",
  "description": "Web-native, zero-dependency, and edge-ready Model Context Protocol (MCP) framework for Hono",
  "author": "rhk <fabien.antoine@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhanka/mcp-hono.git"
  },
  "homepage": "https://github.com/rhanka/mcp-hono#readme",
  "bugs": {
    "url": "https://github.com/rhanka/mcp-hono/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "mcp-hono": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-playground.js",
    "test": "node scripts/verify-playground-design-system.js && node scripts/verify-package-publishing.js && node scripts/verify-oauth-resource-server.js",
    "test:design": "node scripts/verify-playground-design-system.js",
    "test:oauth": "node scripts/verify-oauth-resource-server.js",
    "test:publish": "node scripts/verify-package-publishing.js",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "hono": "^4.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "dependencies": {
    "@sentropic/design-system-tokens": "^0.7.0"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.4",
    "@types/node": "^24.0.0",
    "hono": "^4.0.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
